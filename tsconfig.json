{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "paths": {
      "@config/*":  ["./config/*"],
      "@screens/*": ["./appium/screens/*"],
      "@scripts/*": ["./scripts/*"]
    }
  },
  "include": [
    "config/**/*.ts",
    "appium/**/*.ts",
    "percy/**/*.ts",
    "accessibility/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "reports"]
}
