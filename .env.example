# ─── BrowserStack ────────────────────────────────────────────────────────────
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# App hashes — populated automatically by `npm run upload:android|ios`
# Paste the returned `bs://` URL here or pass as a CI environment variable
BS_ANDROID_APP_HASH=bs://PLACEHOLDER_APP_HASH
BS_IOS_APP_HASH=bs://PLACEHOLDER_APP_HASH

# BrowserStack project label shown in the dashboard (optional)
BS_PROJECT_NAME=Mobile QA Pipeline

# ─── MobSF ───────────────────────────────────────────────────────────────────
MOBSF_URL=http://localhost:8000
MOBSF_API_KEY=

# ─── Percy Visual Testing ────────────────────────────────────────────────────
PERCY_TOKEN=

# ─── Notifications ───────────────────────────────────────────────────────────
SLACK_WEBHOOK=
DISCORD_WEBHOOK=

# ─── Test configuration ───────────────────────────────────────────────────────
# Target environment: staging | production
TEST_ENV=staging

# Test credentials — never commit real values; use GitHub Secrets in CI
TEST_USERNAME=placeholder@example.com
TEST_PASSWORD=PlaceholderPassword1!

# ─── Logging ─────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | silent
LOG_LEVEL=info

# ─── Pipeline report summaries (set by CI after each step) ───────────────────
# These are populated automatically — leave blank locally
REPORT_SECURITY=
REPORT_API=
REPORT_SMOKE=
REPORT_REGRESSION=
REPORT_VISUAL=
REPORT_A11Y=
