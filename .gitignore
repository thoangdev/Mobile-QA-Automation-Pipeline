# ─── Node ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# ─── Environment ─────────────────────────────────────────────────────────────
# Ignore real env files; keep .env.example (it is the committed template)
.env
.env.local
.env.*.local

# ─── App Binaries ────────────────────────────────────────────────────────────
# Built APK/IPA files must not be committed — upload via `npm run upload:android|ios`
apps/**/*.apk
apps/**/*.ipa
apps/**/*.aab

# ─── Test Reports & Artifacts ────────────────────────────────────────────────
reports/
coverage/
allure-results/
allure-report/

# ─── WebdriverIO / Appium ────────────────────────────────────────────────────
.wdio-logs/
logs/
wdio-logs/

# ─── Percy ───────────────────────────────────────────────────────────────────
percy-snapshots/

# ─── Build Outputs ───────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Misc ────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
