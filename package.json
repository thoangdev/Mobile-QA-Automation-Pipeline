{
  "name": "mobile-quality-pipeline",
  "version": "1.0.0",
  "description": "Enterprise mobile QA automation pipeline — functional, API, visual, security, and accessibility validation in a single CI/CD flow.",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test:smoke":      "wdio run appium/config/android.conf.ts --grep @smoke",
    "test:regression": "wdio run appium/config/android.conf.ts",
    "test:api":        "ts-node scripts/run-newman.ts",
    "test:visual":     "percy exec -- wdio run appium/config/android.conf.ts",
    "test:a11y":       "ts-node accessibility/axe-config.ts",
    "scan:mobsf":      "ts-node scripts/run-mobsf.ts",
    "upload:android":  "ts-node scripts/upload-browserstack.ts android",
    "upload:ios":      "ts-node scripts/upload-browserstack.ts ios",
    "notify:slack":    "ts-node scripts/send-slack-notification.ts",
    "notify:discord":  "ts-node scripts/send-discord-notification.ts",
    "validate:env":    "ts-node scripts/validate-env.ts",
    "lint":            "eslint . --ext .ts",
    "lint:fix":        "eslint . --ext .ts --fix",
    "format":          "prettier --write \"**/*.{ts,json,yml,md}\"",
    "format:check":    "prettier --check \"**/*.{ts,json,yml,md}\"",
    "pipeline":        "npm run validate:env && npm run scan:mobsf && npm run test:api && npm run test:smoke && npm run test:regression"
  },
  "dependencies": {
    "@percy/appium-app": "^2.0.3",
    "@wdio/browserstack-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/junit-reporter": "^9.0.0",
    "webdriverio": "^9.0.0",
    "appium": "^2.5.0",
    "dotenv": "^16.4.0",
    "newman": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
